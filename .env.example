# ───────────────────────────────────────────────────────────────────────────
# Multi-Store Hub — environment template (documentation only).
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.
# ───────────────────────────────────────────────────────────────────────────

# Node / app
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL
DATABASE_URL=postgresql://hub:hub@localhost:5432/multi_store_hub?schema=public

# JWT — generate strong random strings, e.g. `openssl rand -hex 48`
JWT_ACCESS_SECRET=replace-with-very-long-random-string
JWT_REFRESH_SECRET=replace-with-another-very-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# AES-256-GCM key for encrypting WooCommerce credentials at rest.
# Must be a 64-char hex string (32 bytes). Generate with: `openssl rand -hex 32`
ENCRYPTION_KEY=replace-with-64-char-hex-string-32-bytes-xxxxxxxxxxxxxxxx

# Foreign proxy used for sites with network_route = VIA_FOREIGN_PROXY
# Format: http://user:pass@host:port  (or set FOREIGN_PROXY_USERNAME/PASSWORD separately)
FOREIGN_PROXY_URL=http://proxy.example.com:8080
FOREIGN_PROXY_USERNAME=
FOREIGN_PROXY_PASSWORD=

# Per-route HTTP tuning (ms)
HTTP_TIMEOUT_DIRECT_MS=15000
HTTP_TIMEOUT_PROXY_MS=30000
HTTP_RETRIES_DIRECT=2
HTTP_RETRIES_PROXY=3

# Throttler (login brute-force protection)
THROTTLE_TTL=60000
THROTTLE_LIMIT=5

# Redis (reserved for Phase 2 — BullMQ; not used in Phase 1)
REDIS_URL=redis://localhost:6379

# Anthropic API (reserved for Phase 4 — AI matching)
ANTHROPIC_API_KEY=
