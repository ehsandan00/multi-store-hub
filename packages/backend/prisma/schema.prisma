// Prisma schema for Multi-Store Hub
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum ProductType {
  SIMPLE
  VARIABLE
  VARIATION
}

enum Role {
  ADMIN
  WAREHOUSE_STAFF
  VIEWER
}

enum NetworkRoute {
  DIRECT
  VIA_FOREIGN_PROXY
}

enum SitePlatform {
  WOOCOMMERCE
  NOPCOMMERCE_ASPNET
}

enum MatchStatus {
  PENDING_REVIEW
  APPROVED
  MANUAL
}

enum InventoryChangeReason {
  SALE
  MANUAL_ADJUSTMENT
  IMPORT
  SYNC
}

enum ImportJobStatus {
  PREVIEW // uploaded + validated; awaiting user confirmation
  PROCESSING // worker applying changes
  COMPLETED // finished successfully (may still contain per-row failures)
  FAILED // fatal failure before/at processing time
  CANCELLED // user dismissed the preview
}

enum SyncJobStatus {
  QUEUED // enqueued, waiting for a worker
  PROCESSING // worker pushing/pulling
  COMPLETED // finished (may still contain per-item failures)
  FAILED // fatal failure before/at processing time
  CANCELLED // user cancelled the queued job
}

enum SyncDirection {
  PUSH // hub → site
  PULL // site → hub (orders, Phase 4)
}

enum MatchingJobStatus {
  PREVIEW // parsed + scored; suggestions written as PENDING_REVIEW
  PROCESSING // worker running AI review batch
  COMPLETED
  FAILED
  CANCELLED
}

enum LogisticsOrderStatus {
  SENT
  NEED_PRODUCT
  CANCELED
}

// ─── Auth & users ─────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(VIEWER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inventoryLogs           InventoryLog[]
  auditLogs               AuditLog[]
  importJobs              ImportJob[]
  syncJobs                SyncJob[]
  matchingJobs            MatchingJob[]
  logisticsOrders         LogisticsOrder[] @relation("LogisticsOrderCreator")
  assignedLogisticsOrders LogisticsOrder[] @relation("LogisticsOrderEmployee")

  @@index([role])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  target    String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

// ─── Products & inventory ─────────────────────────────────────────────────

model Product {
  id                  String      @id @default(uuid())
  skuMaster           String      @unique
  name                String
  description         String?
  category            String?
  basePrice           Decimal     @db.Decimal(12, 2)
  expiryDate          DateTime?
  totalStock          Int         @default(0)
  lowStockThreshold   Int         @default(0)
  imageUrl            String?
  /// Hub-only product photo for warehouse identification; never synced to stores.
  hubPhotoPath        String?
  barcode             String?
  productType         ProductType @default(SIMPLE)
  /// Parent hub product when this row is a variation (productType=VARIATION).
  parentId            String?
  /// Attribute map for variations, e.g. {"Color":"Red","Size":"L"}.
  variationAttributes Json?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  parent              Product?             @relation("ProductVariations", fields: [parentId], references: [id], onDelete: SetNull)
  variations          Product[]            @relation("ProductVariations")
  siteMappings        SiteProductMapping[]
  inventoryLogs       InventoryLog[]
  orderItems          OrderItem[]
  logisticsOrderItems LogisticsOrderItem[]
  expiryBatches       ProductExpiryBatch[]

  @@index([category])
  @@index([expiryDate])
  @@index([name])
  @@index([barcode])
  @@index([parentId])
  @@index([productType])
}

model ProductExpiryBatch {
  id         String   @id @default(uuid())
  productId  String
  expiryDate DateTime
  quantity   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([expiryDate])
}

model InventoryLog {
  id              String                @id @default(uuid())
  productId       String
  changeAmount    Int
  reason          InventoryChangeReason
  sourceSiteId    String?
  createdByUserId String?
  createdAt       DateTime              @default(now())

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceSite SiteConfig? @relation(fields: [sourceSiteId], references: [id], onDelete: SetNull)
  user       User?       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([reason])
  @@index([createdAt])
}

// ─── Sites ────────────────────────────────────────────────────────────────

model SiteConfig {
  id                      String       @id @default(uuid())
  name                    String
  baseUrl                 String
  platform                SitePlatform @default(WOOCOMMERCE)
  consumerKeyEncrypted    String
  consumerSecretEncrypted String
  networkRoute            NetworkRoute @default(DIRECT)
  isActive                Boolean      @default(true)
  // Phase 3: scheduled sync config. The scheduler enqueues a PUSH sync for
  // every site with syncEnabled=true at syncIntervalMs. Manual pushes via the
  // admin UI bypass these (they enqueue immediately regardless).
  syncEnabled             Boolean      @default(false)
  syncIntervalMs          Int          @default(600000) // 10 min default
  lastSyncAt              DateTime?
  // Phase 4: scheduled order-pull config. The scheduler enqueues a PULL sync
  // for every site with orderPullEnabled=true when lastOrderPullAt is older
  // than syncIntervalMs. Manual pulls bypass these.
  orderPullEnabled        Boolean      @default(false)
  lastOrderPullAt         DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  siteMappings  SiteProductMapping[]
  orders        Order[]
  customers     Customer[]
  syncLogs      SyncLog[]
  syncJobs      SyncJob[]
  matchingJobs  MatchingJob[]
  inventoryLogs InventoryLog[]

  @@index([isActive])
  @@index([platform])
  @@index([syncEnabled])
  @@index([orderPullEnabled])
}

model SyncLog {
  id        String   @id @default(uuid())
  siteId    String
  syncType  String
  status    String
  details   Json?
  createdAt DateTime @default(now())

  site SiteConfig @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([syncType])
  @@index([createdAt])
}

// ─── Defined now, wired in later phases ───────────────────────────────────

model SiteProductMapping {
  id                String      @id @default(uuid())
  productId         String
  siteId            String
  siteSku           String?
  siteProductId     String?
  siteSpecificTitle String?
  matchConfidence   Float?
  matchAiReasoning  String?     @db.Text
  matchStatus       MatchStatus @default(MANUAL)
  lastSyncedAt      DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  site    SiteConfig @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([productId, siteId])
  @@index([siteId])
  @@index([matchStatus])
}

model Customer {
  id               String   @id @default(uuid())
  name             String
  phone            String?
  email            String?
  siteId           String?
  remoteCustomerId Int?
  totalOrdersCount Int      @default(0)
  totalSpent       Decimal  @default(0) @db.Decimal(12, 2)
  notes            String?
  createdAt        DateTime @default(now())

  site   SiteConfig? @relation(fields: [siteId], references: [id], onDelete: SetNull)
  orders Order[]

  @@unique([siteId, remoteCustomerId])
  @@index([siteId])
  @@index([phone])
  @@index([email])
}

model Order {
  id            String    @id @default(uuid())
  orderNumber   String
  siteId        String
  customerId    String?
  status        String    @default("pending")
  totalAmount   Decimal   @db.Decimal(12, 2)
  // Phase 4: WooCommerce remote linkage + pull metadata
  remoteOrderId Int?
  dateCreated   DateTime?
  dateModified  DateTime?
  currency      String?
  paymentMethod String?
  discountTotal Decimal   @default(0) @db.Decimal(12, 2)
  shippingTotal Decimal   @default(0) @db.Decimal(12, 2)
  billingName   String?
  billingEmail  String?
  billingPhone  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  site     SiteConfig  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    OrderItem[]

  @@unique([siteId, remoteOrderId])
  @@index([siteId])
  @@index([createdAt])
  @@index([dateCreated])
  @@index([status])
}

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String
  productId    String?
  quantity     Int
  unitPrice    Decimal @db.Decimal(12, 2)
  remoteLineId String?
  siteSku      String?
  lineName     String?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([siteSku])
}

// ─── Manual logistics orders ───────────────────────────────────────────────

model LogisticsOrder {
  id              String               @id @default(uuid())
  orderNumber     String               @unique
  receiverName    String
  phone           String
  city            String
  status          LogisticsOrderStatus
  createdByUserId String?
  employeeId      String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  createdBy User?                @relation("LogisticsOrderCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  employee  User?                @relation("LogisticsOrderEmployee", fields: [employeeId], references: [id], onDelete: SetNull)
  items     LogisticsOrderItem[]

  @@index([status])
  @@index([createdAt])
  @@index([receiverName])
  @@index([phone])
  @@index([city])
  @@index([createdByUserId])
  @@index([employeeId])
}

model LogisticsOrderItem {
  id               String @id @default(uuid())
  logisticsOrderId String
  productId        String
  quantity         Int
  productName      String
  skuMaster        String

  logisticsOrder LogisticsOrder @relation(fields: [logisticsOrderId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([logisticsOrderId])
  @@index([productId])
}

// ─── Import jobs (Phase 2: Excel import/export) ────────────────────────────

model ImportJob {
  id              String          @id @default(uuid())
  kind            String          @default("PRODUCT_IMPORT")
  status          ImportJobStatus @default(PREVIEW)
  fileName        String
  totalRows       Int             @default(0)
  newCount        Int             @default(0)
  updateCount     Int             @default(0)
  errorCount      Int             @default(0)
  // Filled in by the worker after commit:
  createdCount    Int             @default(0)
  updatedCount    Int             @default(0)
  failedCount     Int             @default(0)
  // Structured payload:
  // - errors: [{ row, sku, message }]
  // - rows:   validated rows pending commit (cleared after commit to save space)
  // - report: final summary after commit
  errors          Json?
  rows            Json?
  /// SiteMapping sheet rows pending commit (cleared after commit).
  mappingRows     Json?
  report          Json?
  createdByUserId String?
  createdAt       DateTime        @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?

  user User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
  @@index([createdByUserId])
}

// ─── Matching jobs (Phase 5: AI product matching) ───────────────────────────

model MatchingJob {
  id              String            @id @default(uuid())
  siteId          String
  status          MatchingJobStatus @default(PREVIEW)
  fileName        String
  totalRows       Int               @default(0)
  suggestedCount  Int               @default(0)
  rejectedCount   Int               @default(0)
  reviewCount     Int               @default(0)
  aiReviewCount   Int               @default(0)
  errors          Json?
  report          Json?
  createdByUserId String?
  createdAt       DateTime          @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?

  site SiteConfig @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User?      @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([siteId])
  @@index([status])
  @@index([createdAt])
}

// ─── Sync jobs (Phase 3: WooCommerce sync, hub → site) ──────────────────────

model SyncJob {
  id              String        @id @default(uuid())
  siteId          String
  direction       SyncDirection @default(PUSH)
  status          SyncJobStatus @default(QUEUED)
  // What to sync: 'ALL' pushes every hub product to the site; 'MAPPING' pushes
  // only products with a SiteProductMapping; 'PRODUCT_IDS' pushes a specific
  // set (carried in payload.productIds).
  scope           String        @default("ALL")
  totalItems      Int           @default(0)
  pushedCount     Int           @default(0)
  failedCount     Int           @default(0)
  // Structured payload:
  // - errors: [{ sku, message, code? }]
  // - productIds: string[] (only when scope=PRODUCT_IDS)
  // - report: final summary
  errors          Json?
  payload         Json?
  report          Json?
  createdByUserId String?
  createdAt       DateTime      @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?

  site SiteConfig @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User?      @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([siteId])
  @@index([status])
  @@index([createdAt])
  @@index([createdByUserId])
}
