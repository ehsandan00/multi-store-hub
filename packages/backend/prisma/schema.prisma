// Prisma schema for Multi-Store Hub
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  WAREHOUSE_STAFF
  VIEWER
}

enum NetworkRoute {
  DIRECT
  VIA_FOREIGN_PROXY
}

enum MatchStatus {
  PENDING_REVIEW
  APPROVED
  MANUAL
}

enum InventoryChangeReason {
  SALE
  MANUAL_ADJUSTMENT
  IMPORT
  SYNC
}

// ─── Auth & users ─────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(VIEWER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inventoryLogs InventoryLog[]
  auditLogs     AuditLog[]

  @@index([role])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  target    String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

// ─── Products & inventory ─────────────────────────────────────────────────

model Product {
  id                String   @id @default(uuid())
  skuMaster         String   @unique
  name              String
  description       String?
  category          String?
  basePrice         Decimal  @db.Decimal(12, 2)
  expiryDate        DateTime?
  totalStock        Int      @default(0)
  lowStockThreshold Int      @default(0)
  imageUrl          String?
  barcode           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  siteMappings  SiteProductMapping[]
  inventoryLogs InventoryLog[]
  orderItems    OrderItem[]

  @@index([category])
  @@index([expiryDate])
  @@index([name])
}

model InventoryLog {
  id              String                 @id @default(uuid())
  productId       String
  changeAmount    Int
  reason          InventoryChangeReason
  sourceSiteId    String?
  createdByUserId String?
  createdAt       DateTime               @default(now())

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceSite SiteConfig? @relation(fields: [sourceSiteId], references: [id], onDelete: SetNull)
  user       User?       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([reason])
  @@index([createdAt])
}

// ─── Sites ────────────────────────────────────────────────────────────────

model SiteConfig {
  id                      String       @id @default(uuid())
  name                    String
  baseUrl                 String
  consumerKeyEncrypted    String
  consumerSecretEncrypted String
  networkRoute            NetworkRoute @default(DIRECT)
  isActive                Boolean      @default(true)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  siteMappings SiteProductMapping[]
  orders       Order[]
  customers    Customer[]
  syncLogs     SyncLog[]
  inventoryLogs InventoryLog[]

  @@index([isActive])
}

model SyncLog {
  id        String   @id @default(uuid())
  siteId    String
  syncType  String
  status    String
  details   Json?
  createdAt DateTime @default(now())

  site SiteConfig @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([syncType])
  @@index([createdAt])
}

// ─── Defined now, wired in later phases ───────────────────────────────────

model SiteProductMapping {
  id                String      @id @default(uuid())
  productId         String
  siteId            String
  siteSku           String?
  siteProductId     String?
  siteSpecificTitle String?
  matchConfidence   Float?
  matchStatus       MatchStatus @default(MANUAL)
  lastSyncedAt      DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  site    SiteConfig  @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([productId, siteId])
  @@index([siteId])
  @@index([matchStatus])
}

model Customer {
  id               String   @id @default(uuid())
  name             String
  phone            String?
  email            String?
  siteId           String?
  totalOrdersCount Int      @default(0)
  totalSpent       Decimal  @default(0) @db.Decimal(12, 2)
  notes            String?
  createdAt        DateTime @default(now())

  site   SiteConfig? @relation(fields: [siteId], references: [id], onDelete: SetNull)
  orders Order[]

  @@index([siteId])
  @@index([phone])
}

model Order {
  id          String   @id @default(uuid())
  orderNumber String
  siteId      String
  customerId  String?
  status      String   @default("pending")
  totalAmount Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site     SiteConfig  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    OrderItem[]

  @@index([siteId])
  @@index([createdAt])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String?
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}
