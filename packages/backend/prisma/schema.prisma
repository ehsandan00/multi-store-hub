// Prisma schema for Multi-Store Hub
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  WAREHOUSE_STAFF
  VIEWER
}

enum NetworkRoute {
  DIRECT
  VIA_FOREIGN_PROXY
}

enum MatchStatus {
  PENDING_REVIEW
  APPROVED
  MANUAL
}

enum InventoryChangeReason {
  SALE
  MANUAL_ADJUSTMENT
  IMPORT
  SYNC
}

enum ImportJobStatus {
  PREVIEW // uploaded + validated; awaiting user confirmation
  PROCESSING // worker applying changes
  COMPLETED // finished successfully (may still contain per-row failures)
  FAILED // fatal failure before/at processing time
  CANCELLED // user dismissed the preview
}

enum SyncJobStatus {
  QUEUED // enqueued, waiting for a worker
  PROCESSING // worker pushing/pulling
  COMPLETED // finished (may still contain per-item failures)
  FAILED // fatal failure before/at processing time
  CANCELLED // user cancelled the queued job
}

enum SyncDirection {
  PUSH // hub → site
  PULL // site → hub (orders/inventory, Phase 5)
}

// ─── Auth & users ─────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(VIEWER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inventoryLogs InventoryLog[]
  auditLogs     AuditLog[]
  importJobs    ImportJob[]
  syncJobs      SyncJob[]

  @@index([role])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  target    String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

// ─── Products & inventory ─────────────────────────────────────────────────

model Product {
  id                String    @id @default(uuid())
  skuMaster         String    @unique
  name              String
  description       String?
  category          String?
  basePrice         Decimal   @db.Decimal(12, 2)
  expiryDate        DateTime?
  totalStock        Int       @default(0)
  lowStockThreshold Int       @default(0)
  imageUrl          String?
  barcode           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  siteMappings  SiteProductMapping[]
  inventoryLogs InventoryLog[]
  orderItems    OrderItem[]

  @@index([category])
  @@index([expiryDate])
  @@index([name])
}

model InventoryLog {
  id              String                @id @default(uuid())
  productId       String
  changeAmount    Int
  reason          InventoryChangeReason
  sourceSiteId    String?
  createdByUserId String?
  createdAt       DateTime              @default(now())

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceSite SiteConfig? @relation(fields: [sourceSiteId], references: [id], onDelete: SetNull)
  user       User?       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([reason])
  @@index([createdAt])
}

// ─── Sites ────────────────────────────────────────────────────────────────

model SiteConfig {
  id                      String       @id @default(uuid())
  name                    String
  baseUrl                 String
  consumerKeyEncrypted    String
  consumerSecretEncrypted String
  networkRoute            NetworkRoute @default(DIRECT)
  isActive                Boolean      @default(true)
  // Phase 3: scheduled sync config. The scheduler enqueues a PUSH sync for
  // every site with syncEnabled=true at syncIntervalMs. Manual pushes via the
  // admin UI bypass these (they enqueue immediately regardless).
  syncEnabled             Boolean      @default(false)
  syncIntervalMs          Int          @default(600000) // 10 min default
  lastSyncAt              DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  siteMappings  SiteProductMapping[]
  orders        Order[]
  customers     Customer[]
  syncLogs      SyncLog[]
  syncJobs      SyncJob[]
  inventoryLogs InventoryLog[]

  @@index([isActive])
  @@index([syncEnabled])
}

model SyncLog {
  id        String   @id @default(uuid())
  siteId    String
  syncType  String
  status    String
  details   Json?
  createdAt DateTime @default(now())

  site SiteConfig @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([syncType])
  @@index([createdAt])
}

// ─── Defined now, wired in later phases ───────────────────────────────────

model SiteProductMapping {
  id                String      @id @default(uuid())
  productId         String
  siteId            String
  siteSku           String?
  siteProductId     String?
  siteSpecificTitle String?
  matchConfidence   Float?
  matchStatus       MatchStatus @default(MANUAL)
  lastSyncedAt      DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  site    SiteConfig @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([productId, siteId])
  @@index([siteId])
  @@index([matchStatus])
}

model Customer {
  id               String   @id @default(uuid())
  name             String
  phone            String?
  email            String?
  siteId           String?
  totalOrdersCount Int      @default(0)
  totalSpent       Decimal  @default(0) @db.Decimal(12, 2)
  notes            String?
  createdAt        DateTime @default(now())

  site   SiteConfig? @relation(fields: [siteId], references: [id], onDelete: SetNull)
  orders Order[]

  @@index([siteId])
  @@index([phone])
}

model Order {
  id          String   @id @default(uuid())
  orderNumber String
  siteId      String
  customerId  String?
  status      String   @default("pending")
  totalAmount Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site     SiteConfig  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    OrderItem[]

  @@index([siteId])
  @@index([createdAt])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String?
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

// ─── Import jobs (Phase 2: Excel import/export) ────────────────────────────

model ImportJob {
  id              String          @id @default(uuid())
  kind            String          @default("PRODUCT_IMPORT")
  status          ImportJobStatus @default(PREVIEW)
  fileName        String
  totalRows       Int             @default(0)
  newCount        Int             @default(0)
  updateCount     Int             @default(0)
  errorCount      Int             @default(0)
  // Filled in by the worker after commit:
  createdCount    Int             @default(0)
  updatedCount    Int             @default(0)
  failedCount     Int             @default(0)
  // Structured payload:
  // - errors: [{ row, sku, message }]
  // - rows:   validated rows pending commit (cleared after commit to save space)
  // - report: final summary after commit
  errors          Json?
  rows            Json?
  report          Json?
  createdByUserId String?
  createdAt       DateTime        @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?

  user User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
  @@index([createdByUserId])
}

// ─── Sync jobs (Phase 3: WooCommerce sync, hub → site) ──────────────────────

model SyncJob {
  id          String         @id @default(uuid())
  siteId      String
  direction   SyncDirection  @default(PUSH)
  status      SyncJobStatus  @default(QUEUED)
  // What to sync: 'ALL' pushes every hub product to the site; 'MAPPING' pushes
  // only products with a SiteProductMapping; 'PRODUCT_IDS' pushes a specific
  // set (carried in payload.productIds).
  scope       String         @default("ALL")
  totalItems  Int            @default(0)
  pushedCount Int            @default(0)
  failedCount Int            @default(0)
  // Structured payload:
  // - errors: [{ sku, message, code? }]
  // - productIds: string[] (only when scope=PRODUCT_IDS)
  // - report: final summary
  errors      Json?
  payload     Json?
  report      Json?
  createdByUserId String?
  createdAt   DateTime       @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  site SiteConfig @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User?      @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([siteId])
  @@index([status])
  @@index([createdAt])
  @@index([createdByUserId])
}
