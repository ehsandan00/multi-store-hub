# Dependencies
node_modules/
.pnpm-store/
.venv/
__pycache__/
*.py[cod]

# Build outputs
dist/
build/
.next/
*.tsbuildinfo
# Stray compiled Vite config artifacts (vite.config.ts is the source)
packages/admin/vite.config.js
packages/admin/vite.config.d.ts

# Environment & secrets
.env
.env.local
.env.*.local
!.env.example

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
*.swp

# Test / coverage
coverage/
.nyc_output/
*.lcov
.pytest_cache/

# Prisma generated client (committed via prisma generate; ignore local artifacts)
packages/backend/prisma/migrations/dev.db*
packages/backend/**/*.sqlite
packages/backend/**/*.sqlite-journal

# Hub-only product photos (never synced to stores)
packages/backend/data/hub-photos/

# Generated ASP.NET backup discovery exports (may contain commercial catalog data)
integrations/aspnet-product-sync/discovery/artifacts/

.turbo/
*.pem
